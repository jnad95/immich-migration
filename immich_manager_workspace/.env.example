# Immich Environment Variables Template
# Copy this file to '.env' and fill in your custom values

# Local filesystem locations on your SSD
UPLOAD_LOCATION=/Volumes/PortableSSD/03_Media/immich-library
DB_DATA_LOCATION=/Volumes/PortableSSD/03_Media/immich-data/postgres
MODEL_CACHE_LOCATION=/Volumes/PortableSSD/03_Media/immich-data/model-cache

# Immich release version
IMMICH_VERSION=release

# Database configuration
DB_PASSWORD=immich_ssd_pass
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Host Timezone
TZ=UTC

# Immich CLI & Ingestion configuration
IMMICH_API_KEY=your_immich_api_key_here
IMMICH_INSTANCE_URL=http://localhost:2283/api
